<%
  const shortId = String(document.id || '').slice(0, 8);
  const isArchived = String(document.status || '').toLowerCase() === 'archived';
%>
<header class="page-header">
  <h1><%= template.name %></h1>
  <p class="muted">Template: <%= template.name %> (<code><%= template.key %></code>) · Version: <code>v<%= document.templateVersion ?? 1 %></code> · Workflow: <code><%= template.workflowRef || workflowRuntime?.ref || 'legacy' %></code> · Group: <strong><%= groupName || '—' %></strong> · Status: <span class="badge badge-status"><%= document.status %></span> · Document: <code><%= shortId %></code></p>
  <% if (workflowTimeline && workflowTimeline.length > 0) { %>
    <p class="workflow-timeline">
      <% workflowTimeline.forEach((state, index) => { %>
        <% if (index > 0) { %><span class="muted">→</span><% } %>
        <span class="badge <%= String(state).toLowerCase() === String(document.status).toLowerCase() ? 'badge-status' : '' %>"><%= state %></span>
      <% }) %>
    </p>
  <% } %>
</header>
<% if (isArchived) { %>
  <div class="card">
    <strong>Archived document:</strong> This document is read-only.
  </div>
<% } %>
<section class="card">
  <h3 class="card-title">Assignments</h3>
  <p class="muted">Editors: <strong><%= assignmentEditorName || '—' %></strong> · Approvers: <strong><%= assignmentApproverName || '—' %></strong></p>
  <% if (workflowEvaluation) { %>
    <p class="muted">
      Submit mode: <span class="badge"><%= workflowEvaluation.submitMode %></span>
      · Submissions: <span class="badge"><%= workflowEvaluation.submissionState %></span>
      <% if (useMultiAssignments) { %> · <span><%= submittedEditorCount || 0 %>/<%= (assignedEditorsDetailed || []).length %> submitted</span><% } %>
    </p>
    <p class="muted">
      Approval mode: <span class="badge"><%= workflowEvaluation.approvalMode %></span>
      · Approvals: <span class="badge"><%= workflowEvaluation.approvalState %></span>
      <% if (useMultiAssignments) { %> · <span><%= approvedApproverCount || 0 %>/<%= (assignedApprovers || []).length %> approved<% if ((rejectedApproverCount || 0) > 0) { %>, <%= rejectedApproverCount %> rejected<% } %></span><% } %>
    </p>
  <% } %>
  <% if (useMultiAssignments) { %>
    <div class="row">
      <div class="col col-6">
        <label>Assigned Editors</label>
        <% if ((assignedEditorsDetailed || []).length === 0) { %>
          <p class="muted">—</p>
        <% } %>
        <% (assignedEditorsDetailed || []).forEach((member) => { %>
          <form method="post" action="/documents/<%= document.id %>/assign/editor/remove" class="row">
            <input type="hidden" name="userId" value="<%= member.id %>" />
            <div class="col"><span><%= member.name %> (@<%= member.username %>) · <span class="badge"><%= member.submissionStatus %></span><% if (member.submittedAt) { %> · <span class="muted"><%= new Date(member.submittedAt).toLocaleString() %></span><% } %></span></div>
            <% if (!isArchived) { %><div class="col"><button class="btn btn-secondary" type="submit">Remove</button></div><% } %>
          </form>
        <% }) %>
      </div>
      <div class="col col-6">
        <label>Assigned Approvers</label>
        <% if ((assignedApprovers || []).length === 0) { %>
          <p class="muted">—</p>
        <% } %>
        <% (assignedApprovers || []).forEach((member) => { %>
          <form method="post" action="/documents/<%= document.id %>/assign/approver/remove" class="row">
            <input type="hidden" name="userId" value="<%= member.id %>" />
            <div class="col"><span><%= member.name %> (@<%= member.username %>) · <span class="badge"><%= member.approvalStatus %></span><% if (member.decidedAt) { %> · <span class="muted"><%= new Date(member.decidedAt).toLocaleString() %></span><% } %></span></div>
            <% if (!isArchived) { %><div class="col"><button class="btn btn-secondary" type="submit">Remove</button></div><% } %>
          </form>
        <% }) %>
      </div>
    </div>
  <% } %>
  <% if (isArchived) { %>
    <p class="muted">Assignments are locked for archived documents.</p>
  <% } else if (!hasDocumentActorColumns) { %>
    <p class="muted">Assignments unavailable until DB migration is applied.</p>
  <% } else if (!assignmentGroupId) { %>
    <p class="muted">No group assigned</p>
  <% } else { %>
    <details <%= assignmentsOpen ? 'open' : '' %>>
      <summary class="btn btn-secondary"><%= hasAnyAssignments ? 'Change assignments' : 'Edit assignments' %></summary>
      <form method="post" action="/documents/<%= document.id %>/assign/editor" class="row">
        <div class="col col-6">
          <label for="editor-user-id">Editor</label>
          <select id="editor-user-id" name="userId">
            <% (assignmentEditorCandidates || []).forEach((member) => { %>
              <option value="<%= member.id %>" <%= !useMultiAssignments && document.editorUserId === member.id ? 'selected' : '' %>><%= member.name %> (@<%= member.username %>)</option>
            <% }) %>
          </select>
          <% if (assignmentEditorHint) { %>
            <p class="muted"><%= assignmentEditorHint %></p>
          <% } %>
        </div>
        <div class="col">
          <button class="btn btn-secondary" type="submit"><%= useMultiAssignments ? 'Add Editor' : 'Set Editor' %></button>
        </div>
      </form>
      <form method="post" action="/documents/<%= document.id %>/assign/approver" class="row">
        <div class="col col-6">
          <label for="approver-user-id">Approver</label>
          <select id="approver-user-id" name="userId">
            <% (assignmentApproverCandidates || []).forEach((member) => { %>
              <option value="<%= member.id %>" <%= !useMultiAssignments && document.approverUserId === member.id ? 'selected' : '' %>><%= member.name %> (@<%= member.username %>)</option>
            <% }) %>
          </select>
          <% if (assignmentApproverHint) { %>
            <p class="muted"><%= assignmentApproverHint %></p>
          <% } %>
        </div>
        <div class="col">
          <button class="btn btn-secondary" type="submit"><%= useMultiAssignments ? 'Add Approver' : 'Set Approver' %></button>
        </div>
      </form>
    </details>
  <% } %>
</section>
<% if (errorMessage) { %>
  <div class="card error-card">
    <strong>Action failed:</strong> <%= errorMessage %>
  </div>
<% } %>
<% if (successMessage) { %>
  <div class="card success-card">
    <strong>Success:</strong> <%= successMessage %>
  </div>
<% } %>

<div class="actions">
<% if (!isArchived) { %>
<% (processButtons || []).forEach((button) => {
%>
  <button class="btn btn-primary" type="submit" form="document-form" formaction="/documents/<%= document.id %>/action/<%= button.key %>" formmethod="post"><%= button.label %></button>
<% }) %>
<% } %>
</div>

<form id="document-form" method="post" action="/documents/<%= document.id %>/save" class="card">
  <%- layoutHtml %>
</form>
<div class="actions">
  <a class="btn btn-secondary" href="/documents">Back to Documents</a>
  <a class="btn btn-secondary" href="/templates">Templates</a>
</div>
<script>
  document.addEventListener('submit', function (event) {
    var form = event.target;
    if (!(form instanceof HTMLFormElement)) return;
    var submitter = event.submitter;
    if (!(submitter instanceof HTMLElement)) return;
    var actionKey = submitter.getAttribute('data-fp-action-key');
    var kind = submitter.getAttribute('data-fp-action-kind');
    if (!actionKey || !kind) return;
    var url = submitter.getAttribute('formaction') || form.getAttribute('action') || '';
    console.log('[fp] submit action ' + actionKey + ' kind=' + kind + ' url=' + url);
  });
</script>
