<%
  const shortId = String(document.id || '').slice(0, 8);
%>
<header class="page-header">
  <h1><%= template.name %></h1>
  <p class="muted">Template: <%= template.name %> (<code><%= template.key %></code>) · Version: <code>v<%= document.templateVersion ?? 1 %></code> · Group: <strong><%= groupName || '—' %></strong> · Status: <span class="badge badge-status"><%= document.status %></span> · Document: <code><%= shortId %></code></p>
  <% if (workflowTimeline && workflowTimeline.length > 0) { %>
    <p class="workflow-timeline">
      <% workflowTimeline.forEach((state, index) => { %>
        <% if (index > 0) { %><span class="muted">→</span><% } %>
        <span class="badge <%= state === document.status ? 'badge-status' : '' %>"><%= state %></span>
      <% }) %>
    </p>
  <% } %>
</header>
<section class="card">
  <h3 class="card-title">Assignments</h3>
  <p class="muted">Editor: <strong><%= assignmentEditorName || '—' %></strong></p>
  <p class="muted">Approver: <strong><%= assignmentApproverName || '—' %></strong></p>
  <% if (!hasDocumentActorColumns) { %>
    <p class="muted">Assignments unavailable until DB migration is applied.</p>
  <% } else if (!assignmentGroupId) { %>
    <p class="muted">No group assigned</p>
  <% } else { %>
    <form method="post" action="/documents/<%= document.id %>/assign/editor" class="row">
      <div class="col col-6">
        <label for="editor-user-id">Editor</label>
        <select id="editor-user-id" name="userId">
          <% (assignmentEditorCandidates || []).forEach((member) => { %>
            <option value="<%= member.id %>" <%= document.editorUserId === member.id ? 'selected' : '' %>><%= member.name %> (@<%= member.username %>)</option>
          <% }) %>
        </select>
        <% if (assignmentEditorHint) { %>
          <p class="muted"><%= assignmentEditorHint %></p>
        <% } %>
      </div>
      <div class="col">
        <button class="btn btn-secondary" type="submit">Set Editor</button>
      </div>
    </form>
    <form method="post" action="/documents/<%= document.id %>/assign/approver" class="row">
      <div class="col col-6">
        <label for="approver-user-id">Approver</label>
        <select id="approver-user-id" name="userId">
          <% (assignmentApproverCandidates || []).forEach((member) => { %>
            <option value="<%= member.id %>" <%= document.approverUserId === member.id ? 'selected' : '' %>><%= member.name %> (@<%= member.username %>)</option>
          <% }) %>
        </select>
        <% if (assignmentApproverHint) { %>
          <p class="muted"><%= assignmentApproverHint %></p>
        <% } %>
      </div>
      <div class="col">
        <button class="btn btn-secondary" type="submit">Set Approver</button>
      </div>
    </form>
  <% } %>
</section>
<% if (errorMessage) { %>
  <div class="card error-card">
    <strong>Action failed:</strong> <%= errorMessage %>
  </div>
<% } %>

<form id="document-form" method="post" action="/documents/<%= document.id %>/save" class="card">
  <%- layoutHtml %>
  <div class="actions">
  <% (buttonKeys || []).forEach((controlKey) => {
    const control = (templateJson.controls || {})[controlKey] || {};
    const label = control.label || controlKey;
  %>
    <form method="post" action="/documents/<%= document.id %>/action/<%= controlKey %>">
      <button class="btn btn-primary" type="submit" form="document-form" formaction="/documents/<%= document.id %>/action/<%= controlKey %>" formmethod="post"><%= label %></button>
    </form>
  <% }) %>
  </div>
</form>
<div class="actions">
  <a class="btn btn-secondary" href="/documents">Back to Documents</a>
  <a class="btn btn-secondary" href="/templates">Templates</a>
</div>
