<header class="page-header">
  <h1>Documents</h1>
</header>
<div class="actions">
  <a class="btn btn-secondary" href="/templates">Back to Templates</a>
</div>

<% if (!documents || documents.length === 0) { %>
  <div class="card">
    <p class="muted">No documents yet.</p>
  </div>
<% } %>

<% (documents || []).forEach((doc) => { %>
  <div class="card">
    <div>
      <strong><a href="/documents/<%= doc.id %>">Document</a></strong>
      <span class="muted">· <%= new Date(doc.createdAt).toLocaleString() %></span>
    </div>
    <div>
      Status: <span class="badge badge-status"><%= doc.status %></span>
      · Template: <code><%= doc.templateKey %></code> (<%= doc.templateName %>)
    </div>
    <% if (doc.snapshotPreview && doc.snapshotPreview.length > 0) { %>
      <div class="muted">Snapshots: <%= doc.snapshotPreview.join(' · ') %></div>
    <% } %>
    <div class="actions">
      <a class="btn btn-primary" href="/documents/<%= doc.id %>">Open</a>
    </div>
  </div>
<% }) %>
