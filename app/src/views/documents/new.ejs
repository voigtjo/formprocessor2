<% if (!template) { %>
  <header class="page-header">
    <h1>New Document</h1>
  </header>
  <form method="get" action="/documents/new" class="card">
    <div class="row">
      <div class="col col-6">
        <label for="templateId">Template</label>
        <select id="templateId" name="templateId" required>
          <option value="">Please choose...</option>
          <% (templates || []).forEach((tpl) => { %>
            <option value="<%= tpl.id %>" <%= selectedTemplateId === tpl.id ? 'selected' : '' %>><%= tpl.name %> (<%= tpl.key %>)</option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="actions">
      <button class="btn btn-primary" type="submit">Create</button>
      <a class="btn btn-secondary" href="/templates">Back to Templates</a>
    </div>
  </form>
<% } else { %>
  <header class="page-header">
    <h1>New Document: <%= template.name %></h1>
  </header>
  <% if (unassignedTemplateWarning) { %>
    <div class="card warning-card">
      <strong>Unassigned template</strong>
    </div>
  <% } %>
  <% if (assignedGroupName) { %>
    <div class="card">
      <p class="muted">Group: <strong><%= assignedGroupName %></strong></p>
    </div>
  <% } %>
  <% if (groupChosenNote) { %>
    <div class="card">
      <p class="muted"><%= groupChosenNote %></p>
    </div>
  <% } %>

  <form id="doc-form" method="post" action="/documents" class="card">
    <input type="hidden" name="templateId" value="<%= template.id %>" />

    <%- layoutHtml %>

    <div class="actions">
      <button class="btn btn-primary" type="submit">Create Document</button>
      <a class="btn btn-secondary" href="/templates">Back to Templates</a>
    </div>
  </form>
<% } %>
