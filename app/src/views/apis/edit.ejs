<header class="page-header">
  <h1>Edit API</h1>
  <p class="muted">ID: <code><%= api.id %></code></p>
</header>

<% if (errorMessage) { %>
  <div class="card error-card">
    <strong>Save failed:</strong> <%= errorMessage %>
  </div>
<% } %>

<form method="post" action="/apis/<%= api.id %>" class="card">
  <div class="row">
    <div class="col col-6">
      <label for="key">Key</label>
      <input id="key" name="key" type="text" value="<%= form?.key ?? '' %>" required />
    </div>
    <div class="col col-6">
      <label for="name">Name</label>
      <input id="name" name="name" type="text" value="<%= form?.name ?? '' %>" required />
    </div>
  </div>

  <div class="row">
    <div class="col col-6">
      <label for="description">Description</label>
      <input id="description" name="description" type="text" value="<%= form?.description ?? '' %>" />
    </div>
    <div class="col col-3">
      <label for="state">State</label>
      <select id="state" name="state" required>
        <% ['active', 'inactive'].forEach((stateOption) => { %>
          <option value="<%= stateOption %>" <%= (form?.state ?? 'active') === stateOption ? 'selected' : '' %>><%= stateOption %></option>
        <% }) %>
      </select>
    </div>
    <div class="col col-3">
      <label for="method">Method</label>
      <select id="method" name="method" required>
        <% ['GET', 'POST', 'PUT', 'PATCH', 'DELETE'].forEach((methodOption) => { %>
          <option value="<%= methodOption %>" <%= (form?.method ?? 'GET') === methodOption ? 'selected' : '' %>><%= methodOption %></option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="row">
    <div class="col col-6">
      <label for="base_url">Base URL</label>
      <input id="base_url" name="base_url" type="text" value="<%= form?.base_url ?? '' %>" required />
    </div>
    <div class="col col-6">
      <label for="path">Path</label>
      <input id="path" name="path" type="text" value="<%= form?.path ?? '' %>" required />
    </div>
  </div>

  <div class="row"><div class="col"><label for="request_schema_json">request_schema_json</label><textarea id="request_schema_json" name="request_schema_json" rows="6"><%= form?.request_schema_json ?? '' %></textarea></div></div>
  <div class="row"><div class="col"><label for="response_schema_json">response_schema_json</label><textarea id="response_schema_json" name="response_schema_json" rows="6"><%= form?.response_schema_json ?? '' %></textarea></div></div>
  <div class="row"><div class="col"><label for="handler_code">handler_code (optional)</label><textarea id="handler_code" name="handler_code" rows="6"><%= form?.handler_code ?? '' %></textarea></div></div>

  <div class="actions">
    <button class="btn btn-primary" type="submit">Save API</button>
    <a class="btn btn-secondary" href="/apis/<%= api.id %>">Cancel</a>
  </div>
</form>
