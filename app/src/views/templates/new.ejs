<header class="page-header">
  <h1>New Template</h1>
</header>

<% if (errorMessage) { %>
  <div class="card error-card">
    <strong>Save failed:</strong> <%= errorMessage %>
  </div>
<% } %>

<form method="post" action="/templates" class="card">
  <div class="row">
    <div class="col col-6">
      <label for="key">Key</label>
      <input id="key" name="key" type="text" value="<%= form?.key ?? '' %>" required />
    </div>
    <div class="col col-6">
      <label for="name">Name</label>
      <input id="name" name="name" type="text" value="<%= form?.name ?? '' %>" required />
    </div>
  </div>

  <div class="row">
    <div class="col col-6">
      <label for="description">Description</label>
      <input id="description" name="description" type="text" value="<%= form?.description ?? '' %>" />
    </div>
    <div class="col col-6">
      <label for="state">State</label>
      <input id="state" name="state" type="text" value="<%= form?.state ?? 'active' %>" required />
    </div>
  </div>

  <div class="row">
    <div class="col">
      <label for="template_json">template_json</label>
      <textarea id="template_json" name="template_json" rows="22"><%= form?.template_json ?? '' %></textarea>
    </div>
  </div>

  <div class="actions">
    <button class="btn btn-primary" type="submit">Create Template</button>
    <a class="btn btn-secondary" href="/templates">Back to Templates</a>
  </div>
</form>
