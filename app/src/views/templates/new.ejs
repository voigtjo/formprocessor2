<header class="page-header">
  <h1>New Template</h1>
</header>

<% if (errorMessage) { %>
  <div class="card error-card">
    <strong>Save failed:</strong> <%= errorMessage %>
  </div>
<% } %>
<% if (warnings && warnings.length > 0) { %>
  <div class="card">
    <strong>Compatibility warnings:</strong>
    <ul>
      <% warnings.forEach((warning) => { %>
        <li><%= warning %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<form method="post" action="/templates" class="card">
  <div class="row">
    <div class="col col-6">
      <label for="key">Key</label>
      <input id="key" name="key" type="text" value="<%= form?.key ?? '' %>" required />
    </div>
    <div class="col col-6">
      <label for="name">Name</label>
      <input id="name" name="name" type="text" value="<%= form?.name ?? '' %>" required />
    </div>
  </div>

  <div class="row">
    <div class="col col-6">
      <label for="description">Description</label>
      <input id="description" name="description" type="text" value="<%= form?.description ?? '' %>" />
    </div>
    <div class="col col-6">
      <label for="state">State</label>
      <select id="state" name="state" required>
        <% ['draft', 'published', 'inactive'].forEach((stateOption) => { %>
          <option value="<%= stateOption %>" <%= (form?.state ?? 'draft') === stateOption ? 'selected' : '' %>><%= stateOption %></option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="row">
    <div class="col col-6">
      <label for="workflow_ref">Workflow</label>
      <select id="workflow_ref" name="workflow_ref" required>
        <% (workflows || []).forEach((workflow) => { %>
          <option value="<%= workflow.key %>" <%= (form?.workflow_ref ?? '') === workflow.key ? 'selected' : '' %>><%= workflow.name %> (<%= workflow.key %> v<%= workflow.version %>)</option>
        <% }) %>
      </select>
    </div>
  </div>

  <%- include('_builder', { form, isInactiveTemplate: false }) %>

  <div class="actions">
    <button class="btn btn-primary" type="submit">Create Template</button>
    <a class="btn btn-secondary" href="/templates">Back to Templates</a>
  </div>
</form>
