<header class="page-header">
  <h1><%= template.name %></h1>
  <p class="muted">
    Key: <code><%= template.key %></code>
    · Version: <code>v<%= template.version %></code>
    · State: <span class="badge"><%= normalizedState %></span>
    · Workflow: <code><%= template.workflowRef || '—' %></code>
  </p>
</header>

<div class="card">
  <h3 class="card-title">Template Overview</h3>
  <p><%= template.description || 'No description.' %></p>
  <% if (workflow) { %>
    <p><a href="/workflows/<%= workflow.id %>">Open workflow <%= workflow.name %></a></p>
  <% } else if (template.workflowRef) { %>
    <p class="muted">Referenced workflow currently not available in the active workflow list.</p>
  <% } %>
</div>

<div class="card">
  <h3 class="card-title">Document Data View</h3>
  <p class="muted">System columns come from the document runtime. Additional columns come from <code>template_json.documentTable.columns</code>.</p>
  <table>
    <thead>
      <tr>
        <th>Document</th>
        <th>Status</th>
        <th>Created</th>
        <th>Updated</th>
        <th>Editors</th>
        <th>Approvers</th>
        <% (documentTableColumns || []).forEach((column) => { %>
          <th><%= column.label %></th>
        <% }) %>
      </tr>
    </thead>
    <tbody>
      <% if (!documentTableRows || documentTableRows.length === 0) { %>
        <tr>
          <td colspan="<%= 6 + ((documentTableColumns || []).length) %>" class="muted">No documents for this template yet.</td>
        </tr>
      <% } %>
      <% (documentTableRows || []).forEach((row) => { %>
        <tr>
          <td><a href="/documents/<%= row.id %>"><code><%= row.shortId %></code></a></td>
          <td><span class="badge"><%= row.status %></span></td>
          <td><%= row.createdAt ? new Date(row.createdAt).toLocaleString() : '—' %></td>
          <td><%= row.updatedAt ? new Date(row.updatedAt).toLocaleString() : '—' %></td>
          <td><%= row.editors && row.editors.length > 0 ? row.editors.join(', ') : '—' %></td>
          <td><%= row.approvers && row.approvers.length > 0 ? row.approvers.join(', ') : '—' %></td>
          <% (row.values || []).forEach((value) => { %>
            <td><%= value.value %></td>
          <% }) %>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="card">
  <h3 class="card-title">Template Actions</h3>
  <% if (!usedActions || usedActions.length === 0) { %>
    <p class="muted">No fachliche actions defined.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Action</th>
          <th>Type</th>
          <th>Step Types</th>
          <th>operationRefs</th>
          <th>API Refs</th>
        </tr>
      </thead>
      <tbody>
        <% usedActions.forEach((action) => { %>
          <tr>
            <td><code><%= action.actionKey %></code></td>
            <td><%= action.actionType %></td>
            <td><%= action.stepTypes && action.stepTypes.length > 0 ? action.stepTypes.join(', ') : '—' %></td>
            <td><%= action.operationRefs && action.operationRefs.length > 0 ? action.operationRefs.join(', ') : '—' %></td>
            <td><%= action.apiRefs && action.apiRefs.length > 0 ? action.apiRefs.join(', ') : '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card">
  <h3 class="card-title">Referenced TypeScript Operations</h3>
  <% if (missingOperationRefs && missingOperationRefs.length > 0) { %>
    <div class="error-card">
      <strong>Warning:</strong> Missing operation refs: <%= missingOperationRefs.join(', ') %>
    </div>
  <% } %>
  <% if (!usedOperations || usedOperations.length === 0) { %>
    <p class="muted">No operationRefs referenced.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>operationRef</th>
          <th>Connector</th>
          <th>Auth</th>
          <th>Handler / Module</th>
          <th>Usage</th>
        </tr>
      </thead>
      <tbody>
        <% usedOperations.forEach((operation) => { %>
          <tr>
            <td><code><%= operation.ref %></code></td>
            <td><%= operation.exists ? `${operation.connectorName} (${operation.connectorKey})` : 'missing' %></td>
            <td><%= operation.exists ? operation.authType : '—' %></td>
            <td><%= operation.exists ? operation.modulePath : '—' %></td>
            <td><%= operation.exists ? operation.usableIn.join(', ') : '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<div class="card">
  <h3 class="card-title">Referenced Bridge APIs</h3>
  <% if (missingApiRefs && missingApiRefs.length > 0) { %>
    <div class="error-card">
      <strong>Warning:</strong> Missing API refs: <%= missingApiRefs.join(', ') %>
    </div>
  <% } %>
  <% if (!usedApis || usedApis.length === 0) { %>
    <p class="muted">No APIs referenced.</p>
  <% } else { %>
    <ul>
      <% usedApis.forEach((api) => { %>
        <li>
          <code><%= api.ref %></code>
          <% if (api.exists && api.id) { %>
            · <a href="/apis/<%= api.id %>"><%= api.name || api.key %></a>
          <% } else { %>
            · <span class="muted">missing</span>
          <% } %>
        </li>
      <% }) %>
    </ul>
  <% } %>
</div>

<div class="card">
  <h3 class="card-title">Reference Case</h3>
  <p class="muted">For <code>customer-order-test</code>, the visible integration path should be: lookup field via <code>customers.listValid</code>, form action via <code>customerOrders.create</code>, then workflow hook via <code>customerOrders.setStatusFromContext</code>. The hook reads persisted integration context written by the form action.</p>
</div>

<div class="actions">
  <a class="btn btn-secondary" href="/templates/<%= template.id %>/edit">Edit JSON</a>
  <a class="btn btn-secondary" href="/templates/<%= template.id %>/preview">Preview</a>
  <% if (normalizedState === 'published') { %>
    <a class="btn btn-primary" href="/documents/new?templateId=<%= template.id %>">New Document</a>
  <% } %>
  <a class="btn btn-secondary" href="/templates">Back to Templates</a>
</div>
