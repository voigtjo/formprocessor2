<header class="page-header">
  <h1>Templates</h1>
</header>
<div class="actions">
  <a class="btn btn-secondary" href="/documents">View Documents</a>
  <a class="btn btn-primary" href="/templates/new">Create Template</a>
</div>

<% if (!templates || templates.length === 0) { %>
  <div class="card">
    <p class="muted">No active templates found.</p>
  </div>
<% } %>

<% (templates || []).forEach((tpl) => { %>
  <div class="card">
    <div class="row">
      <div class="col">
        <strong><%= tpl.name %></strong> (<code><%= tpl.key %></code>)
      </div>
      <div class="col">
        <span class="badge">Version <%= tpl.version %></span>
        <span class="badge">State <%= tpl.state %></span>
      </div>
    </div>
    <% if (tpl.description) { %>
      <div class="muted"><%= tpl.description %></div>
    <% } %>
    <div class="actions">
      <a class="btn btn-secondary" href="/templates/<%= tpl.id %>/preview">Preview</a>
      <a class="btn btn-secondary" href="/templates/<%= tpl.id %>/edit">Edit JSON</a>
      <a class="btn btn-primary" href="/documents/new?templateId=<%= tpl.id %>">New Document</a>
    </div>
  </div>
<% }); %>
