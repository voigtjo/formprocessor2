<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= (typeof title !== 'undefined' && title) ? title : 'FormProcessor' %></title>
  <link rel="stylesheet" href="/public/styles.css" />
  <script src="https://unpkg.com/htmx.org@1.9.12"></script>
</head>
<body>
  <div class="container">
    <nav class="top-nav">
      <div class="top-nav-links">
        <a class="btn btn-secondary" href="/templates">Templates</a>
        <a class="btn btn-secondary" href="/documents">Documents</a>
        <a class="btn btn-secondary" href="/admin/debug">RBAC Debug</a>
      </div>
      <% if (typeof users !== 'undefined' && users && users.length > 0) { %>
        <div>
          <label for="active-user">User</label>
          <select id="active-user" onchange="if (this.value) { window.location.href = '/users/switch?userId=' + encodeURIComponent(this.value) + '&next=' + encodeURIComponent('<%= currentPath || '/templates' %>'); }">
            <% users.forEach((u) => { %>
              <option value="<%= u.id %>" <%= (currentUser && currentUser.id === u.id) ? 'selected' : '' %>><%= u.displayName %> (@<%= u.username %>)</option>
            <% }) %>
          </select>
        </div>
      <% } %>
    </nav>
    <%- content %>
  </div>
</body>
</html>
