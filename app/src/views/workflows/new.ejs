<header class="page-header">
  <h1>New Workflow</h1>
</header>

<% if (errorMessage) { %>
  <div class="card error-card">
    <strong>Save failed:</strong> <%= errorMessage %>
  </div>
<% } %>

<section class="editor-workspace">
  <div class="card editor-help">
    <h2>Workflow Hooks</h2>
    <p>Workflows can trigger process-side effects. Use <code>hooks.onTransition</code>, <code>hooks.onEnterState</code> or <code>hooks.onWorkflowAction</code>. Each effect should reference an integration via <code>operationRef</code>. <code>apiRef</code> remains as a bridge for older records.</p>
    <pre><code>{
  "hooks": {
    "onTransition": [
      {
        "from": "submitted",
        "to": "approved",
        "effects": [
          {
            "operationRef": "customerOrders.setStatusFromContext",
            "apiRef": "customerOrders.setStatus",
            "request": {
              "status": "approved"
            }
          }
        ]
      }
    ]
  }
}</code></pre>
  </div>

<form method="post" action="/workflows" class="card editor-form">
  <div class="row">
    <div class="col col-6">
      <label for="key">Key</label>
      <input id="key" name="key" type="text" value="<%= form?.key ?? '' %>" required />
    </div>
    <div class="col col-6">
      <label for="name">Name</label>
      <input id="name" name="name" type="text" value="<%= form?.name ?? '' %>" required />
    </div>
  </div>
  <div class="row">
    <div class="col col-6">
      <label for="description">Description</label>
      <input id="description" name="description" type="text" value="<%= form?.description ?? '' %>" />
    </div>
    <div class="col col-6">
      <label for="state">State</label>
      <select id="state" name="state" required>
        <% ['draft', 'active', 'inactive'].forEach((stateOption) => { %>
          <option value="<%= stateOption %>" <%= (form?.state ?? 'draft') === stateOption ? 'selected' : '' %>><%= stateOption %></option>
        <% }) %>
      </select>
    </div>
  </div>

  <div class="row">
    <div class="col">
      <label for="workflow_json">workflow_json</label>
      <textarea id="workflow_json" name="workflow_json" rows="26" data-json-editor="true"><%= form?.workflow_json ?? '' %></textarea>
    </div>
  </div>

  <div class="actions">
    <button class="btn btn-primary" type="submit">Create Workflow</button>
    <a class="btn btn-secondary" href="/workflows">Back</a>
  </div>
</form>
</section>
