<header class="page-header">
  <h1>Macros (Legacy/Advanced)</h1>
  <p class="muted">Primary model is Template Actions + APIs. Macros remain for compatibility.</p>
  <a class="btn btn-primary" href="/macros/new">New Macro</a>
</header>

<form method="get" action="/macros" class="card">
  <div class="row">
    <div class="col col-6">
      <label for="templateId">Filter by Template</label>
      <select id="templateId" name="templateId">
        <option value="">All templates</option>
        <% (templateOptions || []).forEach((tpl) => { %>
          <option value="<%= tpl.id %>" <%= selectedTemplateId === tpl.id ? 'selected' : '' %>>
            <%= tpl.name %> (<%= tpl.key %> v<%= tpl.version %> · <%= tpl.state %>)
          </option>
        <% }) %>
      </select>
    </div>
    <div class="col col-6">
      <label for="templateState">Template State</label>
      <select id="templateState" name="templateState">
        <% ['all', 'published', 'draft', 'inactive'].forEach((stateOption) => { %>
          <option value="<%= stateOption %>" <%= (selectedTemplateState || 'all') === stateOption ? 'selected' : '' %>><%= stateOption %></option>
        <% }) %>
      </select>
    </div>
  </div>
  <div class="actions">
    <button class="btn btn-secondary" type="submit">Apply Filter</button>
  </div>
</form>

<table>
  <thead>
    <tr>
      <th>Ref</th>
      <th>Namespace</th>
      <th>Name</th>
      <th>Version</th>
      <th>Enabled</th>
      <th>Kind</th>
      <th>Description</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (!macros || macros.length === 0) { %>
      <tr><td colspan="8" class="muted">No macros found.</td></tr>
    <% } %>
    <% (macros || []).forEach((macro) => { %>
      <tr>
        <td><code><%= macro.ref %></code></td>
        <td><%= macro.namespace %></td>
        <td><%= macro.name %></td>
        <td><code>v<%= macro.version %></code></td>
        <td><%= macro.isEnabled ? 'yes' : 'no' %></td>
        <td><%= macro.kind || 'json' %></td>
        <td><%= macro.description || '—' %></td>
        <td>
          <a href="/macros/<%= encodeURIComponent(macro.ref) %>">Open</a>
          · <a href="/macros/<%= encodeURIComponent(macro.ref) %>/edit">Edit</a>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
