<header class="page-header">
  <h1>Edit Macro: <code><%= macro.ref %></code></h1>
</header>

<% if (errorMessage) { %>
  <div class="card error-card"><strong>Error:</strong> <%= errorMessage %></div>
<% } %>

<form method="post" action="/macros/<%= encodeURIComponent(macro.ref) %>" class="card">
  <div class="row">
    <div class="col col-6">
      <label for="ref">Ref</label>
      <input id="ref" name="ref" value="<%= form.ref %>" required />
    </div>
    <div class="col col-6">
      <label for="kind">Kind</label>
      <select id="kind" name="kind" required>
        <% ['json', 'code', 'builtin'].forEach((kindOption) => { %>
          <option value="<%= kindOption %>" <%= form.kind === kindOption ? 'selected' : '' %>><%= kindOption %></option>
        <% }) %>
      </select>
    </div>
  </div>
  <div class="row">
    <div class="col col-6">
      <label for="namespace">Namespace</label>
      <input id="namespace" name="namespace" value="<%= form.namespace %>" required />
    </div>
    <div class="col col-6">
      <label for="name">Name</label>
      <input id="name" name="name" value="<%= form.name %>" required />
    </div>
  </div>
  <div class="row">
    <div class="col col-6">
      <label for="version">Version</label>
      <input id="version" name="version" type="number" min="1" step="1" value="<%= form.version %>" required />
    </div>
    <div class="col col-6">
      <label for="enabled">Enabled</label>
      <input id="enabled" name="enabled" type="checkbox" value="1" <%= form.enabled ? 'checked' : '' %> />
    </div>
  </div>
  <label for="description">Description</label>
  <textarea id="description" name="description" rows="3"><%= form.description %></textarea>

  <label for="params_schema_json">Params Schema JSON</label>
  <p class="hint">Optional JSON Schema for macro params.</p>
  <textarea id="params_schema_json" name="params_schema_json" rows="8"><%= form.params_schema_json %></textarea>

  <label for="definition_json">Definition JSON</label>
  <p class="hint">Executable macro definition for <code>kind=json</code>.</p>
  <textarea id="definition_json" name="definition_json" rows="12"><%= form.definition_json %></textarea>

  <label for="code_text">Code Text</label>
  <p class="hint">Reserved for future/trusted system macros; not used by normal JSON macros.</p>
  <textarea id="code_text" name="code_text" rows="12"><%= form.code_text %></textarea>

  <div class="actions">
    <button class="btn btn-primary" type="submit">Save Macro</button>
    <a class="btn btn-secondary" href="/macros/<%= encodeURIComponent(macro.ref) %>">Open</a>
    <a class="btn btn-secondary" href="/macros">Back to Macros</a>
  </div>
</form>
